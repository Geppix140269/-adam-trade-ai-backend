# Port for the API server (Railway will set this automatically)
PORT=3000

# Ollama service URL (use localhost when running in the same container)
OLLAMA_URL=http://localhost:11434

# Allowed origins for CORS (comma-separated)
# For development: http://localhost:3000,http://127.0.0.1:3000
# For production: https://your-netlify-app.netlify.app
ALLOWED_ORIGINS=*

# Node environment
NODE_ENV=production
